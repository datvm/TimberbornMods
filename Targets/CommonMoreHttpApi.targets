<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

	<PropertyGroup>
		<MoreHttpApiPath>$(GameModsFolder)MoreHttpApi\$(TimberbornVersion)\**\*.dll</MoreHttpApiPath>
	</PropertyGroup>

	<ItemGroup>
		<Using Include="MoreHttpApi.Services" />
		<Using Include="MoreHttpApi.Handlers" />
		<Using Include="MoreHttpApi.Models" />
		<Using Include="MoreHttpApi.Shared" />
		<Using Include="MoreHttpApi.Shared.Specs" />
		<Using Include="MoreHttpApi.Shared.BuildingSettings" />
		<Using Include="System.Net" />
		

		<Reference Include="$(MoreHttpApiPath)" Private="false" />
	</ItemGroup>

</Project>