<div class="accordion-item">
    <h2 class="accordion-header">
        <button class="accordion-button @(isOpen ? "" : "collapsed")" @onclick="ToggleAsync">
            @if (Header is null)
            {
                @(Title ?? "")
            }
            else
            {
                @(Header)
            }
        </button>
        
    </h2>

    @if (isOpen)
    {
        <div class="accordion-collapse collapse show">
            <div class="accordion-body">
                @(ChildContent)
            </div>
        </div>
    }
    
</div>