@page "/automations"

@inject ApiService Api;
@inject IJSRuntime JS;
@inject AutomationsService AutomationsSvc;
@inject MermaidChartService MermaidCharts;

<BreadcrumbRenderer Breadcrumb="Breadcrumb.Automations" />

<div class="vstack gap-3">
    @if (automationsModEnabled is null)
    {
        <Spinner />
    }
    else if (automationsModEnabled == false)
    {
        <div class="alert alert-warning">
            Automations require the More HTTP API - Automations mod.
        </div>
    }
    else
    {
        <button class="btn btn-primary" @onclick="GetSnapshot">
            Get snapshot
        </button>

        @if (automationMap is not null)
        {
            var visiblePartitions = GetVisiblePartitions();

            <div class="vstack gap-2">
                <h5>Automators (@(automationMap.Buildings.Count))</h5>

                <div class="row">
                    <div class="col-auto">
                        <label class="form-label" for="automation-view-select">View</label>						
                    </div>
                    <div class="col">
                        <select id="automation-view-select" class="form-select" @bind="selectedView" @bind:after="OnPartitionViewSelected">
                            <option value="">Overview</option>
                            @foreach (var partition in visiblePartitions)
                            {
                                <option value="@partition.Id">Partition @partition.Id (@partition.Automators.Count)</option>
                            }
                        </select>
                    </div>

                    <div class="col-auto">
                        <div class="form-check">
                            <input @bind="hideSingleNodePartitions" @bind:after="OnPartitionViewSelected" class="form-check-input" type="checkbox" id="hideSingleNodePartitions" />
                            <label class="form-check-label" for="hideSingleNodePartitions">
                                Hide partitions with only one node
                            </label>
                        </div>
                    </div>
                </div>
                
                <details>
                    <summary class="mb-2">Mermaid text</summary>
                    <div class="vstack gap-2">
                        <textarea class="form-control" rows="10" readonly>@fullMermaidText</textarea>
                        <div>
                            <button class="btn btn-outline-secondary" @onclick="CopyMermaidAsync">Copy</button>
                        </div>
                    </div>
                </details>

                <mermaid-chart data-content="@(currentMermaidText)" class="w-100" @onnodeclick="OnNodeClick"></mermaid-chart>
            </div>
        }
    }
</div>
